# ============================================================
#  CONTENT FACTORY - CONFIGURACION (EJEMPLO)
#  Copia este archivo a ".env" y rellena tus valores reales.
#  NUNCA subas tu .env real a git (ya está en .gitignore).
# ============================================================

# --- n8n ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=false
# Si activas auth básica, define usuario/clave:
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=cambia_esto

# --- Ollama (proveedor principal de texto, local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- ComfyUI (generación de imágenes, local en Windows) ---
COMFYUI_URL=http://localhost:8188
# OPCIONAL: ruta para que start_all inicie ComfyUI automáticamente.
# Apunta al .bat de arranque (ej. run_nvidia_gpu.bat) o a la carpeta de ComfyUI.
# COMFYUI_PATH=C:\AI\ComfyUI\run_nvidia_gpu.bat
# Nombre EXACTO del checkpoint en ComfyUI/models/checkpoints
COMFYUI_CKPT=sd_xl_base_1.0.safetensors
# Tamaño de generación (vertical 9:16). El video luego rellena a VIDEO_WIDTH/HEIGHT.
COMFYUI_IMG_WIDTH=832
COMFYUI_IMG_HEIGHT=1216
COMFYUI_NEG=lowres, blurry, watermark, text, deformed, ugly

# --- Telegram (aprobación y notificaciones) ---
# Crea un bot con @BotFather y obtén el token.
# Obtén tu chat_id enviando un mensaje al bot y consultando getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Audio narrado ---
# edge-tts es gratuito y local (no requiere clave). Voz por defecto en español:
TTS_PROVIDER=edge
EDGE_TTS_VOICE=es-MX-DaliaNeural

# --- ElevenLabs (OPCIONAL, voz premium de pago) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Proveedores de texto OPCIONALES (no obligatorios) ---
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# --- Parámetros de video ---
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
# Segundos por escena si no hay audio que marque la duración
SCENE_DURATION=5
